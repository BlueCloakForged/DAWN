{
  "title": "ForgeScaffold Test Matrix",
  "type": "object",
  "required": ["project_id", "levels", "units"],
  "properties": {
    "project_id": {"type": "string"},
    "levels": {
      "type": "array",
      "items": {"type": "string", "enum": ["L0_contract", "L1_slice", "L2_smoke", "L3_nonfunctional"]}
    },
    "units": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["unit_id", "type", "success_criteria", "tests"],
        "properties": {
          "unit_id": {"type": "string"},
          "type": {"type": "string"},
          "path": {"type": "string"},
          "success_criteria": {
            "type": "array",
            "items": {"type": "string"}
          },
          "tests": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "level", "command", "artifacts_expected"],
              "properties": {
                "id": {"type": "string"},
                "level": {"type": "string", "enum": ["L0_contract", "L1_slice", "L2_smoke", "L3_nonfunctional"]},
                "command": {"type": "string"},
                "artifacts_expected": {"type": "array", "items": {"type": "string"}}
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
